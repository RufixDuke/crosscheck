{
  "name": "@rufixduke/crosscheck",
  "version": "0.1.1",
  "description": "Local-first, pre-push AI self-review CLI — review what your AI coding agent wrote before you push.",
  "type": "module",
  "bin": {
    "crosscheck": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.18"
  },
  "author": "RufixDuke",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RufixDuke/crosscheck.git"
  },
  "bugs": {
    "url": "https://github.com/RufixDuke/crosscheck/issues"
  },
  "homepage": "https://crosscheck-iota.vercel.app/",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "npm version patch && git push origin main --follow-tags && npm publish"
  },
  "keywords": [
    "code-review",
    "ai",
    "pre-push",
    "cli",
    "git",
    "llm",
    "offline",
    "self-review"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.2",
    "simple-git": "^3.27.0",
    "sql.js": "^1.12.0",
    "ts-morph": "^24.0.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "typescript": ">=5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.9",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
